# ---------------------------------------
#   C++ KOD (korrekt diff + normalisering)
# ---------------------------------------
*.c        text diff=cpp
*.cpp      text diff=cpp
*.h        text diff=cpp
*.hpp      text diff=cpp
*.inl      text diff=cpp

# ---------------------------------------
#   TEXTFILER
# ---------------------------------------
*.txt      text
*.md       text
*.json     text
*.xml      text
*.yml      text
*.yaml     text
*.ini      text
*.cfg      text
*.cmake    text

# ---------------------------------------
#   VISUAL STUDIO (CRLF)
# ---------------------------------------
*.sln      text eol=crlf
*.vcxproj  text eol=crlf
*.filters  text eol=crlf
*.props    text eol=crlf

# ---------------------------------------
#   BINÄRER (ingen diff/merge)
# ---------------------------------------
*.exe      binary
*.dll      binary
*.lib      binary
*.pdb      binary
*.obj      binary
*.ipch     binary
*.db       binary
*.tlog     binary
*.cache    binary

# ---------------------------------------
#   MEDIA / RAYLIB ASSETS
# ---------------------------------------
*.png      binary
*.jpg      binary
*.jpeg     binary
*.bmp      binary
*.tga      binary
*.wav      binary
*.ogg      binary
*.mp3      binary
*.ttf      binary

# ---------------------------------------
#   GIT LFS (valfritt)
# ---------------------------------------
# Exempel om du vill aktivera LFS:
# *.png filter=lfs diff=lfs merge=lfs -text
# *.wav filter=lfs diff=lfs merge=lfs -text
